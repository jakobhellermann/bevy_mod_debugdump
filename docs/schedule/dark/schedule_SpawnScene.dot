		"node_System(SystemKey(4v1))" ["label"="spawn_queued", "tooltip"="bevy_scene::spawn::spawn_queued", "fillcolor"="#bacfcb", "fontname"="Helvetica", "fontcolor"="#141e1c", "color"="#7da59d", "penwidth"="1"]
	}
	
	"node_System(SystemKey(5v1))" ["label"="apply_deferred", "tooltip"="bevy_ecs::apply_deferred"]
