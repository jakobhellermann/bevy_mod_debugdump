		"node_System(SystemKey(2v1))" ["label"="world_instance_spawner_system", "tooltip"="bevy_world_serialization::world_asset_spawner::world_instance_spawner_system", "fillcolor"="#eff1f3", "fontname"="Helvetica", "fontcolor"="#15191d", "color"="#b4bec7", "penwidth"="1"]
	}
	
